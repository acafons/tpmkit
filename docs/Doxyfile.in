PROJECT_NAME           = "@PROJECT_NAME@"
PROJECT_NUMBER         = "@PROJECT_VERSION@"
PROJECT_BRIEF          = "@PROJECT_DESCRIPTION@"
OUTPUT_DIRECTORY       = "@PROJECT_BINARY_DIR@/docs"
INPUT                  = "@PROJECT_SOURCE_DIR@/include/tpmkit"
RECURSIVE              = YES
FILE_PATTERNS          = *.h
STRIP_FROM_PATH        = "@PROJECT_SOURCE_DIR@/include"
FULL_PATH_NAMES        = YES

GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = NO
GENERATE_XML           = NO
HAVE_DOT               = NO
CLASS_GRAPH            = NO
CALL_GRAPH             = NO
CALLER_GRAPH           = NO
COLLABORATION_GRAPH    = NO
INCLUDE_GRAPH          = NO
INCLUDED_BY_GRAPH      = NO

EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_AS_ERROR          = YES
WARN_FORMAT            = "$file:$line: $text"

QUIET                  = NO
JAVADOC_AUTOBRIEF      = NO
QT_AUTOBRIEF           = NO
MULTILINE_CPP_IS_BRIEF = NO
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES
BUILTIN_STL_SUPPORT    = YES
TYPEDEF_HIDES_STRUCT   = NO

ALIASES               += thread_safety="\par Thread Safety"
ALIASES               += exception_safety="\par Exception Safety"

PREDEFINED            += __cplusplus=201703L
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = NO
SKIP_FUNCTION_MACROS   = YES

USE_MDFILE_AS_MAINPAGE =
