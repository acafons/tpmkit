@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

set(_tpmkit_need_production FALSE)
set(_tpmkit_need_testing FALSE)
set(_tpmkit_need_spdlog FALSE)
set(_tpmkit_need_stdio FALSE)

if(NOT tpmkit_FIND_COMPONENTS)
    set(_tpmkit_need_production TRUE)
else()
    foreach(_tpmkit_component IN LISTS tpmkit_FIND_COMPONENTS)
        if(_tpmkit_component STREQUAL "production" OR _tpmkit_component STREQUAL "tpmkit")
            set(_tpmkit_need_production TRUE)
        elseif(_tpmkit_component STREQUAL "testing" OR _tpmkit_component STREQUAL "tpmkit_testing")
            set(_tpmkit_need_production TRUE)
            set(_tpmkit_need_testing TRUE)
        elseif(_tpmkit_component STREQUAL "spdlog" OR _tpmkit_component STREQUAL "tpmkit_spdlog")
            set(_tpmkit_need_production TRUE)
            set(_tpmkit_need_spdlog TRUE)
        elseif(_tpmkit_component STREQUAL "stdio" OR _tpmkit_component STREQUAL "tpmkit_stdio")
            set(_tpmkit_need_production TRUE)
            set(_tpmkit_need_stdio TRUE)
        else()
            set(tpmkit_${_tpmkit_component}_FOUND FALSE)
        endif()
    endforeach()
endif()

find_dependency(Microsoft.GSL CONFIG)
find_dependency(tl-expected CONFIG QUIET)
if(NOT TARGET tl::expected)
    find_path(TPMKIT_TL_EXPECTED_INCLUDE_DIR NAMES tl/expected.hpp REQUIRED)
    add_library(tpmkit_tl_expected_headers INTERFACE)
    target_include_directories(
        tpmkit_tl_expected_headers
        INTERFACE "${TPMKIT_TL_EXPECTED_INCLUDE_DIR}"
    )
    add_library(tl::expected ALIAS tpmkit_tl_expected_headers)
endif()

if(_tpmkit_need_production)
    set(TPMKIT_OPENSSL_REQUIRED_VERSION "@TPMKIT_OPENSSL_REQUIRED_VERSION@")
    set(TPMKIT_TSS2_REQUIRED_VERSION "@TPMKIT_TSS2_REQUIRED_VERSION@")
    find_dependency(PkgConfig)
    pkg_check_modules(OPENSSL_PKG REQUIRED IMPORTED_TARGET
        "openssl = ${TPMKIT_OPENSSL_REQUIRED_VERSION}"
    )
    pkg_check_modules(TSS2_ESYS REQUIRED IMPORTED_TARGET
        "tss2-esys = ${TPMKIT_TSS2_REQUIRED_VERSION}"
    )
    pkg_check_modules(TSS2_TCTILDR REQUIRED IMPORTED_TARGET
        "tss2-tctildr = ${TPMKIT_TSS2_REQUIRED_VERSION}"
    )
    pkg_check_modules(TSS2_RC REQUIRED IMPORTED_TARGET
        "tss2-rc = ${TPMKIT_TSS2_REQUIRED_VERSION}"
    )
endif()

include("${CMAKE_CURRENT_LIST_DIR}/tpmkitTargets.cmake")

set(_tpmkit_spdlog_targets "${CMAKE_CURRENT_LIST_DIR}/tpmkitSpdlogTargets.cmake")
if(_tpmkit_need_spdlog)
    if(EXISTS "${_tpmkit_spdlog_targets}")
        set(TPMKIT_SPDLOG_REQUIRED_VERSION "@TPMKIT_SPDLOG_REQUIRED_VERSION@")
        find_dependency(spdlog ${TPMKIT_SPDLOG_REQUIRED_VERSION} CONFIG)
        include("${_tpmkit_spdlog_targets}")
    else()
        set(tpmkit_NOT_FOUND_MESSAGE
            "Required tpmkit spdlog component was requested, but tpmkitSpdlogTargets.cmake was not installed."
        )
    endif()
endif()

set(_tpmkit_stdio_targets "${CMAKE_CURRENT_LIST_DIR}/tpmkitStdioTargets.cmake")
if(_tpmkit_need_stdio)
    if(EXISTS "${_tpmkit_stdio_targets}")
        include("${_tpmkit_stdio_targets}")
    else()
        set(tpmkit_NOT_FOUND_MESSAGE
            "Required tpmkit stdio component was requested, but tpmkitStdioTargets.cmake was not installed."
        )
    endif()
endif()

if(_tpmkit_need_production)
    set(tpmkit_production_FOUND TRUE)
    set(tpmkit_tpmkit_FOUND TRUE)
endif()

if(_tpmkit_need_testing)
    if(TARGET tpmkit::tpmkit_testing)
        set(tpmkit_testing_FOUND TRUE)
        set(tpmkit_tpmkit_testing_FOUND TRUE)
    else()
        set(tpmkit_testing_FOUND FALSE)
        set(tpmkit_tpmkit_testing_FOUND FALSE)
    endif()
endif()

if(_tpmkit_need_spdlog)
    if(TARGET tpmkit::tpmkit_spdlog)
        set(tpmkit_spdlog_FOUND TRUE)
        set(tpmkit_tpmkit_spdlog_FOUND TRUE)
    else()
        set(tpmkit_spdlog_FOUND FALSE)
        set(tpmkit_tpmkit_spdlog_FOUND FALSE)
    endif()
endif()

if(_tpmkit_need_stdio)
    if(TARGET tpmkit::tpmkit_stdio)
        set(tpmkit_stdio_FOUND TRUE)
        set(tpmkit_tpmkit_stdio_FOUND TRUE)
    else()
        set(tpmkit_stdio_FOUND FALSE)
        set(tpmkit_tpmkit_stdio_FOUND FALSE)
    endif()
endif()

check_required_components(tpmkit)
